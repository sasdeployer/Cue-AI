# Copy to .env and fill in. The server reads ../.env (repo root) or ./.env (server/).
# Provider preference: OpenAI (if set) > Anthropic > canned sample decks.

# OpenAI (recommended)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_REASONING_EFFORT=medium

# Anthropic (alternative)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

DATABASE_URL=postgres://cueai:cueai@localhost:5432/cueai?sslmode=disable
PORT=8080
ALLOW_ORIGIN=http://localhost:5273

# Magic-link login (no passwords). Without RESEND_API_KEY, login links are
# logged to the server console instead of emailed — fine for local dev.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Cue <login@cue.dev>
